# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored — real keys never get committed.
# Every entry point (demo.py, backend.py, chat.py, app.py, agent/*) loads it
# automatically; real environment variables always take precedence.

# The agent's ONLY secret (LLM access) — set one of these:
OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...

# MCP SERVER-side config (forwarded only to the server subprocess, never
# visible to the LLM). Comment out to fall back to the local SQLite file.
COMPANY_DB_DSN=postgresql://mcp_readonly:readonly_pass@localhost:5432/company

# Optional:
# AGENT_PROVIDER=openai            # force provider instead of auto-detect
# OPENAI_AGENT_MODEL=gpt-4o-mini   # OpenAI model override
# AGENT_MODEL=claude-opus-4-8      # Anthropic model override
# COMPANY_DB_PATH=db/company.db    # custom SQLite path
